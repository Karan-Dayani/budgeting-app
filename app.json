{
  "expo": {
    "name": "budgeting-app",
    "slug": "budgeting-app",
    "version": "1.0.0",
    "backgroundColor": "#41B3A2",
    "orientation": "portrait",
    "icon": "./assets/images/Coin.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "package": "com.evilzeus.budgetingapp"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-sharing",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/CointTrack.png",
          "resizeMode": "cover",
          "backgroundColor": "#41B3A2"
        }
      ],
      "expo-status-bar",
      "expo-web-browser",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "7595b5f7-6b5c-4a9a-a770-ec25d96c68d6"
      }
    }
  }
}
